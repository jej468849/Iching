    <div class="big">동효 : <span id="dong"></span></div>
    <hr>
    <div>연수 : <span id="year"></span></div>
    <div>월수 : <span id="month"></span></div>
    <div>일수 : <span id="day"></span></div>
    <div>시수 : <span id="hour"></span></div>
</div>

