    <a href="index.html" class="home-btn">← 돌아가기</a>
</div>

<label>날짜</label>
<input type="date" id="solarDate">

<label>시간</label>
<input type="time" id="solarTime">

<button class="nowBtn" onclick="setNow()">현재시간 불러오기</button>
<button class="calcBtn" onclick="calculate()">작괘하기</button>

<div class="result" id="result">
